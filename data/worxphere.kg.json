  "rules": [
    {
      "id": "02fb5071-6554-4a60-aef8-b18b3fea35c2",
      "name": "로고 비례 변형 금지",
      "expression": "Logo 노드의 간격, 기울기, 비례를 임의로 변형할 수 없다",
      "type": "constraint",
      "condition": {
        "nodeType": "Logo",
        "predicate": "arbitraryProportion",
        "operator": "must_not_have"
      }
    },
    {
      "id": "74ee8b87-ad15-40ad-9d97-dc6de2b29a7b",
      "name": "로고 형태 변형 금지",
      "expression": "Logo 노드의 형태, 두께, 윤곽선을 임의로 변형하거나 부분 변형할 수 없다",
      "type": "constraint",
      "condition": {
        "nodeType": "Logo",
        "predicate": "arbitraryShape",
        "operator": "must_not_have"
      }
    },
    {
      "id": "09f83a89-0508-41ce-a3a7-0c4389820dd8",
      "name": "로고 지정 컬러 외 사용 금지",
      "expression": "Logo 노드에 지정 컬러 외 컬러를 적용할 수 없다",
      "type": "constraint",
      "condition": {
        "nodeType": "Logo",
        "predicate": "nonDesignatedColor",
        "operator": "must_not_have"
      }
    },
    {
      "id": "f457a8fc-52c4-435c-97ae-c73797c8c7fc",
      "name": "로고 효과 적용 금지",
      "expression": "Logo 노드에 효과를 적용하거나 복잡한 배경 위에 사용할 수 없다",
      "type": "constraint",
      "condition": {
        "nodeType": "Logo",
        "predicate": "visualEffect",
        "operator": "must_not_have"
      }
    },
    {
      "id": "fae9f605-48f3-442a-8ad7-48f148585f97",
      "name": "지정 컬러 외 사용 금지",
      "expression": "Color 노드는 가이드라인에 지정된 컬러만 사용해야 하며, 지정되지 않은 배색 조합을 사용할 수 없다",
      "type": "constraint",
      "condition": {
        "nodeType": "Color",
        "predicate": "nonDesignatedColor",
        "operator": "must_not_have"
      }
    },
    {
      "id": "e7acdd36-9876-41b3-84e6-448513768043",
      "name": "컬러 그라디언트 및 투명도 금지",
      "expression": "Color 노드에 그라디언트를 적용하거나 투명도 효과를 중첩할 수 없다",
      "type": "constraint",
      "condition": {
        "nodeType": "Color",
        "predicate": "gradientEffect",
        "operator": "must_not_have"
      }
    },
    {
      "id": "45c92b35-0482-4907-9f5c-e03ca9cd8af3",
      "name": "명도 대비 규정",
      "expression": "Color 노드 사용 시 명도 대비가 낮은 배색을 사용할 수 없으며, 하나의 요소에 지나치게 많은 컬러를 조합할 수 없다",
      "type": "constraint",
      "condition": {
        "nodeType": "Color",
        "predicate": "lowContrastPairing",
        "operator": "must_not_have"
      }
    },
    {
      "id": "f1a891d5-9495-43bd-bcce-88e4ce24ea0c",
      "name": "서체 형태 변형 금지",
      "expression": "Typography 노드의 글자 간격, 굵기, 크기, 형태를 임의로 변형할 수 없다",
      "type": "constraint",
      "condition": {
        "nodeType": "Typography",
        "predicate": "arbitraryDeformation",
        "operator": "must_not_have"
      }
    },
